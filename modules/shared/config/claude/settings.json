{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [
      "codex review *",
      "gh"
    ],
    "filesystem": {
      "allowWrite": [
        "~/.claude/plugins/data/codex-openai-codex",
        "~/.claude/plugins/data/codex-openai-codex/state"
      ],
      "denyRead": [
        "~/.aws/credentials",
        "~/.ssh",
        "~/.gnupg",
        "id_ed25519",
        "id_rsa"
      ]
    }
  },
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(jq *)",
      "Bash(jj *)",
      "mcp__*",
      "ListMcpResourcesTool",
      "ReadMcpResourceTool",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebSearch"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git push *)",
      "Bash(jj rebase *)",
      "Bash(jj git push *)",
      "Bash(chmod 777 *)",
      "Bash(chmod +s *)",
      "Bash(pkill *)",
      "Bash(killall *)",
      "Read(.env)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(id_ed25519)",
      "Read(id_rsa)",
      "Read(**/*secret*)",
      "Read(**/secrets/**)",
      "Write(.env)",
      "Write(*.pem)",
      "Write(*.key)",
      "Write(id_ed25519)",
      "Write(id_rsa)",
      "Write(**/secrets/**)",
      "Write(**/*token*)",
      "Edit(*.pem)",
      "Edit(*.key)",
      "Edit(id_ed25519)",
      "Edit(id_rsa)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notification.sh ask"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notification.sh done"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/enforce-commands.sh",
            "if": "tool_input.command matches '\\b(grep|find|git)\\b'"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_NO_FLICKER": 1
  },
  "showClearContextOnPlanAccept": true,
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  }
}
