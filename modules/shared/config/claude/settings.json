{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [
      "codex review *",
      "gh"
    ],
    "filesystem": {
      "allowWrite": [
        "~/.claude/plugins/data/codex-openai-codex",
        "~/.claude/plugins/data/codex-openai-codex/state"
      ],
      "denyRead": [
        "~/.aws/credentials",
        "~/.ssh"
      ]
    }
  },
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(jq *)",
      "Bash(jj *)",
      "mcp__*",
      "ListMcpResourcesTool",
      "ReadMcpResourceTool"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git push *)",
      "Bash(jj rebase *)",
      "Bash(jj git push *)",
      "Bash(chmod 777 *)",
      "Read(.env*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(id_ed25519)",
      "Read(id_rsa)",
      "Read(**/*secret*)",
      "Read(**/secrets/**)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Write(**/*token*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notification.sh ask"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notification.sh done"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/enforce-commands.sh"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  }
}
