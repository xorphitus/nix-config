[user]
	email = xorphitus@gmail.com
	name = xorphitus
	signingkey = D1807C94682FEF328966ACF1522B834DAD3D20B1
[core]
	pager = delta
	editor = nano
	# This line should be redundant, but somehow jj didn't completely follow the config without this.
	excludesFile = ~/.config/git/ignore
[format]
	signoff = true
[color]
	ui = auto
[commit]
	gpgsign = true
[push]
	default = tracking
[merge]
	ff = false
	conflictStyle = zdiff3 # for delta
[rebase]
	autostash = true
[branch]
	autosetuprebase = always
[pull]
	rebase = true
[alias]
	s = status
	b = branch
	d = diff
	sw = switch
	push-f = push --force-with-lease
[interactive]
	diffFilter = delta --color-only
[ghq]
	root = ~/go/src
	root = ~/.ghq
[github]
	user = xorphitus
[delta]
	navigate = true  # use n and N to move between diff sections
	dark = true      # or light = true, or omit for auto-detection
